# Example environment variables for local development
# Do NOT commit secrets. Keep real keys out of the repo or use platform secrets.

# Server configuration
PORT=8000
# Replace with your News API key (server-side). Do NOT commit the real key.
NEWS_API_KEY=57229faa1bf34cbcbf8bd60c36ef3927
NEWS_API_BASE_URL=https://newsapi.org/v2

# Gemini / Generative Language API (server-side only)
# Set this on the SERVER environment (not in client Vite env). The server will
# forward requests to the AI provider without exposing keys to the browser.
# Provide the raw API key (preferred) or the full provider URL (only for quick
# testing; embedding keys in URLs is less secure).
GEMINI_API_KEY=AIzaSyC23OY6GLdlZdkhzkbuJrJQhnHWZRR0KC0
# Optional: override full provider URL if needed (include the key if you must,
# but prefer GEMINI_API_KEY). Leave blank to use the default endpoint.
GEMINI_API_URL=

# AI rate limiting (optional)
AI_MAX_REQ_PER_MIN=20

# Notes:
# - NEVER commit secrets. This example file should contain placeholders only.
# - Do NOT add a VITE_ prefixed GEMINI key here; VITE_ vars are bundled into the
#   client and will expose your key in browser builds. Use `GEMINI_API_KEY` on
#   the server environment instead and keep it secret via your host's secret
#   manager (Vercel, Netlify, Cloud Run, etc.).
